{
  "functions": {
    "api/*.js": {
      "memory": 512,
      "maxDuration": 10
    },
    "api/checkout/*.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
